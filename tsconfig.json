{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "bcryptjs": ["./src/vendor/bcryptjs/index.js"],
      "next-auth": ["./src/vendor/next-auth/index.ts"],
      "next-auth/jwt": ["./src/vendor/next-auth/jwt.ts"],
      "next-auth/react": ["./src/vendor/next-auth/react.ts"],
      "next-auth/providers/credentials": ["./src/vendor/next-auth/providers/credentials.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
