{
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/golf/scrape?cron=true",
      "schedule": "0 10 * * 1,2,3,4,5"
    },
    {
      "path": "/api/golf/odds-snapshot?cron=true",
      "schedule": "0 14,20,2 * * *"
    },
    {
      "path": "/api/admin/pga-fallback-capture",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/odds/aggregated/snapshot?cron=true&sports=NHL,NBA,MLB",
      "schedule": "17 * * * *"
    },
    {
      "path": "/api/odds/aggregated/snapshot?cron=true&sports=NBA&reason=nba-q1-q3-daily-archive",
      "schedule": "55 17 * * *"
    },
    {
      "path": "/api/systems/refresh?cron=true",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/admin/goose-model/generate-daily",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/admin/goose-model/auto-grade",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/admin/sandbox/auto-grade",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/admin/nhl-shot-refresh?cron=true",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/admin/nhl-shot-refresh?cron=true&mode=full",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/admin/goose-model/mlb-lineup-refresh",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/admin/systems/grade?cron=true",
      "schedule": "0 9 * * *"
    },
    {
      "schedule": "0 7,14,20 * * *",
      "path": "/api/admin/picks/settle-pending?cron=true"
    },
    {
      "path": "/api/admin/goose-model/ingest-production-picks",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/ufc/card",
      "schedule": "0 16 * * *"
    }
  ]
}