{
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/golf/scrape?cron=true",
      "schedule": "0 10 * * 2,3,4"
    },
    {
      "path": "/api/systems/refresh?cron=true",
      "schedule": "0 15 * * *"
    }
  ]
}
